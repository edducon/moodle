{
  "manifest_version": 3,
  "name": "Moodle AI Assistant",
  "version": "0.1",
  "description": "AI-помощник для навигации по курсам Moodle",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://online.mospolytech.ru/*",
                  "*://lms.mospolytech.ru/*"],
      "css": [
        "css/variables.css",
        "css/button.css",
        "css/chat.css",
        "css/deadlines.css",
        "css/highlights.css"
      ],
      "js": [
        "js/utils.js",
        "js/api.js",
        "js/ui.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/logo.png"
      ],
      "matches": [
        "*://online.mospolytech.ru/*",
        "*://lms.mospolytech.ru/*"
      ]
    }
  ]
}